<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <FontFamily x:Key="Font.Family.Default">Segoe UI Variable, Segoe UI</FontFamily>
    <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib" x:Key="Font.Size.Default">12</system:Double>

    <!-- ===================== Base window chrome ===================== -->
    <Style TargetType="Menu">
        <Setter Property="Background" Value="{DynamicResource Brush.Surface}" />
    </Style>
    <Style TargetType="StatusBar">
        <Setter Property="Background" Value="{DynamicResource Brush.Surface}" />
    </Style>

    <!-- ===================== Buttons ===================== -->
    <!-- Flat, restrained command-bar style button — the base every other button variant builds on. -->
    <Style x:Key="Btn.Base" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="#FF344258" />
        <Setter Property="Padding" Value="10,0" />
        <Setter Property="Height" Value="34" />
        <Setter Property="FontFamily" Value="{DynamicResource Font.Family.Default}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6" SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#FFF1F5F9" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Btn.Primary" TargetType="Button" BasedOn="{StaticResource Btn.Base}">
        <Setter Property="Background" Value="{DynamicResource Brush.Accent}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="7" SnapsToDevicePixels="True">
                        <Border.Effect>
                            <DropShadowEffect x:Name="BdShadow" Color="#FF2563EB" Opacity="0.28" BlurRadius="14" ShadowDepth="3" Direction="270" />
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#FF1D4ED8" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                            <Setter TargetName="Bd" Property="Effect" Value="{x:Null}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Compact bordered button, used for "Map Columns", zoom control, mini actions -->
    <Style x:Key="Btn.Mini" TargetType="Button" BasedOn="{StaticResource Btn.Base}">
        <Setter Property="Height" Value="30" />
        <Setter Property="Padding" Value="10,0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="White" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1" CornerRadius="6">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#FFF1F5F9" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Narrow rail icon button -->
    <Style x:Key="Btn.Rail" TargetType="Button" BasedOn="{StaticResource Btn.Base}">
        <Setter Property="Width" Value="38" />
        <Setter Property="Height" Value="38" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="Foreground" Value="#FF68768B" />
    </Style>
    <Style x:Key="Btn.Rail.Active" TargetType="Button" BasedOn="{StaticResource Btn.Rail}">
        <Setter Property="Background" Value="{DynamicResource Brush.Accent.Soft}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Accent}" />
    </Style>

    <!-- Small icon button used inside the dock header (collapse/expand/back) -->
    <Style x:Key="Btn.DockIcon" TargetType="Button" BasedOn="{StaticResource Btn.Base}">
        <Setter Property="Width" Value="28" />
        <Setter Property="Height" Value="28" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Foreground" Value="#FF657287" />
    </Style>

    <!-- Text-only link-style button, e.g. "Edit properties" -->
    <Style x:Key="Btn.Link" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Accent}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <ContentPresenter />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===================== Segmented tab buttons (Contents | Properties) ===================== -->
    <Style x:Key="Segment.RadioButton" TargetType="RadioButton">
        <Setter Property="Height" Value="28" />
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="Foreground" Value="#FF68768B" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="Bd" Background="Transparent" CornerRadius="6">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="White" />
                            <Setter Property="Foreground" Value="#FF243249" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter TargetName="Bd" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#FF172033" Opacity="0.10" BlurRadius="6" ShadowDepth="1" Direction="270" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===================== Inputs ===================== -->
    <Style TargetType="TextBox">
        <Setter Property="Height" Value="30" />
        <Setter Property="Padding" Value="8,0" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Background" Value="White" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Height" Value="30" />
        <Setter Property="Background" Value="White" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
        <Setter Property="Padding" Value="8,0" />
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <!-- ===================== Chips (status pills) ===================== -->
    <Style x:Key="Chip" TargetType="Border">
        <Setter Property="Height" Value="26" />
        <Setter Property="Padding" Value="9,0" />
        <Setter Property="CornerRadius" Value="13" />
        <Setter Property="Background" Value="#FFF1F5F9" />
        <Setter Property="BorderBrush" Value="#FFE4EAF0" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style x:Key="Chip.Text" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="#FF5C697C" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- ===================== TreeView (Contents outline / Project Explorer) ===================== -->
    <Style TargetType="TreeViewItem">
        <Setter Property="Padding" Value="6,7" />
        <Setter Property="Background" Value="Transparent" />
        <Style.Resources>
            <!-- Recolors the built-in selection highlight instead of a full ControlTemplate rewrite. -->
            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#FFEAF1FF" />
            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FF174EA6" />
            <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#FFF5F7FA" />
            <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#FF172033" />
        </Style.Resources>
    </Style>

    <!-- ===================== DataGrid (Excel workspace grid + preview table grids) ===================== -->
    <Style TargetType="DataGrid">
        <Setter Property="Background" Value="White" />
        <Setter Property="RowBackground" Value="White" />
        <Setter Property="AlternatingRowBackground" Value="White" />
        <Setter Property="GridLinesVisibility" Value="All" />
        <Setter Property="HorizontalGridLinesBrush" Value="#FFE8EDF3" />
        <Setter Property="VerticalGridLinesBrush" Value="#FFE5EAF0" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="RowHeaderWidth" Value="0" />
        <Setter Property="FontSize" Value="12" />
    </Style>
    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="#FFF6F8FB" />
        <Setter Property="Foreground" Value="#FF68758A" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="9,0" />
        <Setter Property="Height" Value="31" />
        <Setter Property="BorderBrush" Value="#FFE5EAF0" />
        <Setter Property="BorderThickness" Value="0,0,1,1" />
    </Style>
    <Style TargetType="DataGridCell">
        <Setter Property="Padding" Value="9,0" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Focusable" Value="False" />
    </Style>

</ResourceDictionary>