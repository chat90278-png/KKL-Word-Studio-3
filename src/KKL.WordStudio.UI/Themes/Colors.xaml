<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                     xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Variant 2.5 palette — mapped 1:1 from the approved HTML prototype's
         :root CSS custom properties, so the WPF app uses exactly the same
         colors rather than an approximation. Keys match
         KKL.WordStudio.Shared.Theming.ThemeKeys constants. -->
    <SolidColorBrush x:Key="Brush.App.Background" Color="#FFE9EDF2" />
    <SolidColorBrush x:Key="Brush.Surface" Color="#FFF4F6F8" />
    <SolidColorBrush x:Key="Brush.Surface.Alt" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="Brush.Soft" Color="#FFF8FAFC" />
    <SolidColorBrush x:Key="Brush.Border" Color="#FFD8E0E8" />
    <SolidColorBrush x:Key="Brush.Border.Light" Color="#FFE9EDF2" />
    <SolidColorBrush x:Key="Brush.Accent" Color="#FF2563EB" />
    <SolidColorBrush x:Key="Brush.Accent.Soft" Color="#FFEAF1FF" />
    <SolidColorBrush x:Key="Brush.Text.Primary" Color="#FF172033" />
    <SolidColorBrush x:Key="Brush.Text.Secondary" Color="#FF6D798B" />
    <SolidColorBrush x:Key="Brush.Status.Ok" Color="#FF2F855A" />
    <SolidColorBrush x:Key="Brush.Status.Warn" Color="#FFB7791F" />
    <SolidColorBrush x:Key="Brush.Status.Bad" Color="#FFC53030" />
    <SolidColorBrush x:Key="Brush.HeaderRowHighlight" Color="#FFFFF8DD" />

</ResourceDictionary>
