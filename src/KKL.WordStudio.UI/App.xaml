<Application x:Class="KKL.WordStudio.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:KKL.WordStudio.UI.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Colors.xaml" />
                <ResourceDictionary Source="Themes/Theme.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
            <converters:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisibility" />
            <converters:IndentToThicknessConverter x:Key="IndentToThickness" />
            <converters:HorizontalOnlyThicknessConverter x:Key="HorizontalOnlyThickness" />
            <converters:BindingStatusToBrushConverter x:Key="BindingStatusToBrush" />
            <converters:IsTableToVisibilityConverter x:Key="IsTableToVisibility" />
            <converters:StringToVisibilityConverter x:Key="StringToVisibility" />
            <converters:InverseBooleanConverter x:Key="InverseBool" />
            <converters:EnumEqualsToVisibilityConverter x:Key="EnumEqualsToVisibility" />
            <converters:EnumNotEqualToVisibilityConverter x:Key="EnumNotEqualToVisibility" />
            <converters:EnumEqualsToBoolConverter x:Key="EnumEqualsToBool" />
            <converters:BoolToConfiguredTextConverter x:Key="BoolToConfiguredText" />
            <converters:DockStateToWidthConverter x:Key="DockStateToWidth" />
            <converters:HeaderRowBackgroundConverter x:Key="HeaderRowBackground" />
            <converters:RangeBoundaryThicknessConverter x:Key="RangeBoundaryThickness" />
            <converters:StringEqualsMultiConverter x:Key="StringEquals" />
            <converters:ActiveSheetBackgroundConverter x:Key="ActiveSheetBackground" />
            <converters:ActiveSheetForegroundConverter x:Key="ActiveSheetForeground" />
            <converters:ActiveSheetFontWeightConverter x:Key="ActiveSheetFontWeight" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
