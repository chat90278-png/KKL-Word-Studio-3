<Window x:Class="KKL.WordStudio.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KKL Word Studio"
        Width="1600" Height="950"
        MinWidth="860" MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource Brush.App.Background}">

    <Grid>
        <DockPanel LastChildFill="True">

            <!-- ===================== Title bar ===================== -->
            <Border DockPanel.Dock="Top" Height="40" Background="#FFF9FBFD" BorderBrush="{DynamicResource Brush.Border.Light}" BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal" Margin="12,0">
                    <Image Width="30"
                           Height="30"
                           VerticalAlignment="Center"
                           Stretch="Uniform"
                           Source="Assets/Brand/BrandMarkSmall.png"
                           ToolTip="KKL Word Studio" />
                    <TextBlock Text="KKL Word Studio" FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0,0,0" />
                </StackPanel>
            </Border>

            <!-- ===================== Simplified command bar ===================== -->
            <Border DockPanel.Dock="Top" Height="54" Background="White" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,0,1">
                <DockPanel Margin="14,0">
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                        <ContentControl x:Name="LoadedSourcesHost" VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                        <Button Content="Kullanım Kılavuzu" Style="{StaticResource Btn.Mini}"
                                Command="{Binding ShowUsageGuideCommand}" Height="36" Padding="14,0" Margin="0,0,8,0" />
                        <Button Content="Word Dosyası Oluştur" Style="{StaticResource Btn.Primary}" Command="{Binding ExportToWordCommand}" />
                    </StackPanel>

                    <StackPanel />
                </DockPanel>
            </Border>

            <!-- Compact status area at the very bottom of the window. -->
            <StatusBar DockPanel.Dock="Bottom" Height="28" Background="{DynamicResource Brush.Surface}">
                <StatusBarItem Content="{Binding StatusText}" />
                <StatusBarItem Visibility="{Binding LastExportedFilePath, Converter={StaticResource StringToVisibility}}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="✓ Word dosyası oluşturuldu"
                                   Foreground="{DynamicResource Brush.Text.Secondary}"
                                   VerticalAlignment="Center"
                                   Margin="8,0,10,0" />
                        <Button Content="Dosyayı Aç"
                                Style="{StaticResource Btn.Link}"
                                Command="{Binding OpenExportedFileCommand}"
                                FontSize="11"
                                Margin="0,0,10,0" />
                        <Button Content="Klasörde Göster"
                                Style="{StaticResource Btn.Link}"
                                Command="{Binding OpenExportedFolderCommand}"
                                FontSize="11" />
                    </StackPanel>
                </StatusBarItem>
            </StatusBar>

            <!-- ===================== Responsive workspace ===================== -->
            <Grid x:Name="WorkspaceGrid" ClipToBounds="True">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="420" />
                    <ColumnDefinition Width="28" />
                    <ColumnDefinition x:Name="ReportPaneColumn" Width="Auto" />
                </Grid.ColumnDefinitions>

                <ContentControl x:Name="ExcelWorkspaceHost" Grid.Column="0" />

                <!-- Always-visible narrow edge handle. -->
                <Border Grid.Column="1"
                        Background="#FFF7F9FC"
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="1,0">
                    <Button x:Name="ReportPaneToggleButton"
                            Content="{Binding ReportPane.ToggleText}"
                            Click="ReportPaneToggleButton_Click"
                            ToolTip="{Binding ReportPane.ToggleToolTip}"
                            Style="{StaticResource Btn.Base}"
                            Padding="0"
                            FontSize="18"
                            FontWeight="SemiBold"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center" />
                </Border>

                <!-- Preview and Context Dock travel as one report workspace. -->
                <Border x:Name="ReportPaneShell"
                        Grid.Column="2"
                        Width="760"
                        ClipToBounds="True"
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="1,0,0,0"
                        Background="{DynamicResource Brush.App.Background}">
                    <Grid MinWidth="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="420" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition x:Name="DockColumn" Width="350" />
                        </Grid.ColumnDefinitions>

                        <ContentControl x:Name="PreviewHost" Grid.Column="0" />
                        <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" Background="{DynamicResource Brush.Border}" />
                        <ContentControl x:Name="ContextDockHost" Grid.Column="2" />
                    </Grid>
                </Border>

                <!-- Full-workspace, non-modal usage guide. Existing editor views remain alive underneath. -->
                <Border Grid.ColumnSpan="3" Panel.ZIndex="200"
                        Background="{DynamicResource Brush.App.Background}"
                        Visibility="{Binding IsUsageGuideOpen, Converter={StaticResource BoolToVisibility}}">
                    <ContentControl x:Name="UsageGuideHost" />
                </Border>
            </Grid>
        </DockPanel>

        <!-- Full-shell interaction shield for measured long operations. -->
        <Border Panel.ZIndex="1000"
                Background="#73111A2B"
                Visibility="{Binding LongOperation.IsBusy, Converter={StaticResource BoolToVisibility}}">
            <Border Width="430"
                    MaxWidth="520"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="White"
                    BorderBrush="#FFD5DEEA"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="22">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="28" ShadowDepth="7" Opacity="0.24" />
                </Border.Effect>
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="36" Height="36" CornerRadius="10" Background="#FFEAF2FF">
                            <TextBlock Text="↻"
                                       Foreground="#FF2563EB"
                                       FontSize="21"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding LongOperation.Title}"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="#FF172033" />
                            <TextBlock Text="İşlem tamamlanana kadar diğer komutlar geçici olarak kapalı."
                                       Margin="0,3,0,0"
                                       FontSize="10.5"
                                       Foreground="#FF6B7689" />
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Text="{Binding LongOperation.Detail}"
                               Margin="0,17,0,0"
                               FontSize="12"
                               Foreground="#FF3B4658"
                               TextWrapping="Wrap" />

                    <ProgressBar IsIndeterminate="True"
                                 Height="8"
                                 Margin="0,16,0,0" />

                    <Button Content="İptal"
                            Style="{StaticResource Btn.Mini}"
                            Command="{Binding LongOperation.CancelCommand}"
                            IsEnabled="{Binding LongOperation.IsCancellable}"
                            HorizontalAlignment="Right"
                            Margin="0,16,0,0"
                            Padding="16,0"
                            Height="32" />
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
