<UserControl x:Class="KKL.WordStudio.UI.Views.QuickAssemblyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="540"
             MaxHeight="640">
    <Border Background="White"
            BorderBrush="#FFD8E0EC"
            BorderThickness="1"
            CornerRadius="14">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#FFF7F9FC"
                    BorderBrush="{DynamicResource Brush.Border.Light}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="14,14,0,0"
                    Padding="16,13">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Hızlı Rapor Oluştur"
                                   FontSize="14"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="Seçilen her Excel sayfası yeni bir rapor tablosu olur."
                                   Margin="0,3,0,0"
                                   FontSize="10.5"
                                   Foreground="{DynamicResource Brush.Text.Secondary}" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Content="✕"
                            Style="{StaticResource Btn.Mini}"
                            Command="{Binding ClosePanelCommand}"
                            Width="28"
                            Height="28"
                            Padding="0" />
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="14,10,14,8">
                <Border Background="#FFF8FAFD"
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="16"
                        Visibility="{Binding HasSources, Converter={StaticResource InverseBoolToVisibility}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="Henüz yüklü Excel kaynağı yok."
                                   FontWeight="SemiBold"
                                   TextAlignment="Center" />
                        <TextBlock Text="Önce Excel ekle düğmesiyle dosya açın."
                                   Margin="0,5,0,0"
                                   FontSize="10.5"
                                   Foreground="{DynamicResource Brush.Text.Secondary}" />
                    </StackPanel>
                </Border>

                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Visibility="{Binding HasSources, Converter={StaticResource BoolToVisibility}}">
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer">
                            <Setter Property="IsEnabled" Value="True" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                    <Setter Property="IsEnabled" Value="False" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>
                    <ItemsControl ItemsSource="{Binding Sources}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#FFFAFBFD"
                                        BorderBrush="{DynamicResource Brush.Border}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Margin="0,0,0,9">
                                    <StackPanel>
                                        <Grid Margin="12,10,12,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Content="{Binding DisplayName}"
                                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                      FontWeight="SemiBold"
                                                      ToolTip="{Binding SourcePath}" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Sheets.Count, StringFormat='{}{0} sayfa'}"
                                                       FontSize="9.5"
                                                       Foreground="{DynamicResource Brush.Text.Secondary}" />
                                        </Grid>

                                        <ItemsControl ItemsSource="{Binding Sheets}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="White"
                                                            BorderBrush="{DynamicResource Brush.Border.Light}"
                                                            BorderThickness="0,1,0,0"
                                                            Padding="12,8">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="24" />
                                                                <ColumnDefinition Width="135" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <CheckBox Grid.Column="0"
                                                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                      VerticalAlignment="Center" />
                                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding WorksheetName}"
                                                                           FontWeight="SemiBold"
                                                                           TextTrimming="CharacterEllipsis" />
                                                                <TextBlock Text="{Binding LastResultText}"
                                                                           FontSize="9.5"
                                                                           Foreground="{DynamicResource Brush.Text.Secondary}"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           Visibility="{Binding LastResultText, Converter={StaticResource StringToVisibility}}" />
                                                            </StackPanel>
                                                            <TextBox Grid.Column="2"
                                                                     Text="{Binding Caption, UpdateSourceTrigger=PropertyChanged}"
                                                                     IsEnabled="{Binding IsSelected}"
                                                                     Margin="8,0,0,0"
                                                                     Height="28"
                                                                     VerticalContentAlignment="Center"
                                                                     ToolTip="İsteğe bağlı tablo başlığı" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <Border Grid.Row="2"
                    Background="#FFF7F9FC"
                    BorderBrush="{DynamicResource Brush.Border.Light}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,14,14"
                    Padding="14,11">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Content="Tümünü seç"
                                Style="{StaticResource Btn.Mini}"
                                Command="{Binding SelectAllCommand}"
                                Margin="0,0,6,0" />
                        <Button Grid.Column="1"
                                Content="Temizle"
                                Style="{StaticResource Btn.Mini}"
                                Command="{Binding ClearSelectionCommand}" />
                        <TextBlock Grid.Column="2"
                                   Text="{Binding SelectedCount, StringFormat='{}{0} sayfa seçili'}"
                                   Margin="12,0,0,0"
                                   FontSize="10.5"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Brush.Text.Secondary}"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="3"
                                Content="Seçilenleri Rapora Aktar"
                                Style="{StaticResource Btn.Primary}"
                                Command="{Binding TransferSelectedCommand}"
                                Height="32"
                                Padding="14,0" />
                    </Grid>

                    <Grid Grid.Row="1"
                          Margin="0,9,0,0"
                          Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="{Binding CurrentItemText}"
                                   FontSize="10.5"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" />
                        <Grid Grid.Row="1" Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ProgressBar Grid.Column="0"
                                         Minimum="0"
                                         Maximum="100"
                                         Value="{Binding ProgressPercent}"
                                         Height="7"
                                         VerticalAlignment="Center" />
                            <Button Grid.Column="1"
                                    Content="İptal"
                                    Style="{StaticResource Btn.Mini}"
                                    Command="{Binding CancelTransferSelectedCommand}"
                                    Margin="10,0,0,0" />
                        </Grid>
                    </Grid>

                    <TextBlock Grid.Row="2"
                               Text="{Binding StatusText}"
                               Margin="0,8,0,0"
                               FontSize="10.5"
                               Foreground="{DynamicResource Brush.Text.Secondary}"
                               TextWrapping="Wrap" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
