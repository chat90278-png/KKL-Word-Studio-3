<UserControl x:Class="KKL.WordStudio.UI.Views.QuickAssemblyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="700"
             MaxHeight="760">
    <Border Background="White"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="14"
            Padding="18">
        <Border.Effect>
            <DropShadowEffect BlurRadius="26" ShadowDepth="7" Opacity="0.22" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="HIZLI RAPOR" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource Brush.Text.Secondary}" />
                    <TextBlock Text="Tam rapor yapısı oluştur" Margin="0,4,0,0" FontSize="16" FontWeight="SemiBold" />
                    <TextBlock Text="Sayfaları tıklama sırasıyla seçin. Her seçim başlık, alt başlık ve tablo bloğu olarak rapora eklenir."
                               Margin="0,4,0,0" FontSize="11" Foreground="{DynamicResource Brush.Text.Secondary}" TextWrapping="Wrap" />
                </StackPanel>
                <Button Grid.Column="1" Content="×" Style="{StaticResource Btn.Mini}"
                        Command="{Binding ClosePanelCommand}" Width="32" Height="30" VerticalAlignment="Top" />
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <Border Background="{DynamicResource Brush.Surface.Alt}"
                            BorderBrush="{DynamicResource Brush.Border.Light}"
                            BorderThickness="1" CornerRadius="9" Padding="10"
                            Visibility="{Binding HasSources, Converter={StaticResource InverseBoolToVisibility}}">
                        <TextBlock Text="Önce bir veya daha fazla Excel dosyası ekleyin."
                                   Foreground="{DynamicResource Brush.Text.Secondary}" TextAlignment="Center" />
                    </Border>

                    <Grid Margin="0,0,0,8" Visibility="{Binding HasSources, Converter={StaticResource BoolToVisibility}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="1 · KAYNAK SAYFALARI" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource Brush.Text.Secondary}" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="Tümünü Seç" Style="{StaticResource Btn.Mini}" Command="{Binding SelectAllCommand}" Margin="0,0,6,0" />
                            <Button Content="Temizle" Style="{StaticResource Btn.Mini}" Command="{Binding ClearSelectionCommand}" />
                        </StackPanel>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding Sources}"
                                  Visibility="{Binding HasSources, Converter={StaticResource BoolToVisibility}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource Brush.Border.Light}" BorderThickness="1"
                                        Background="{DynamicResource Brush.Surface.Alt}" CornerRadius="9"
                                        Padding="10" Margin="0,0,0,8">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Content="{Binding DisplayName}" IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                      FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="{Binding SelectedCount, StringFormat='{}{0} seçili'}"
                                                       Foreground="{DynamicResource Brush.Text.Secondary}" FontSize="10" VerticalAlignment="Center" />
                                        </Grid>

                                        <ItemsControl ItemsSource="{Binding Sheets}" Margin="20,7,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,3">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" VerticalAlignment="Center" />
                                                        <TextBlock Grid.Column="1" Text="{Binding WorksheetName}" Margin="7,0,0,0"
                                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                        <Border Grid.Column="2" Background="#FFEAF2FF" CornerRadius="8" Padding="7,2"
                                                                Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibility}}">
                                                            <TextBlock Text="{Binding SelectionOrderText, StringFormat='Sıra {0}'}"
                                                                       FontSize="9.5" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Accent}" />
                                                        </Border>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Separator Margin="0,8,0,14" />

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="2 · RAPOR YAPISI" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource Brush.Text.Secondary}" />
                            <TextBlock Text="Sıra ilk tıklamaya göre oluşur; oklarla sonradan değiştirebilirsiniz."
                                       Margin="0,3,0,0" FontSize="10.5" Foreground="{DynamicResource Brush.Text.Secondary}" />
                        </StackPanel>
                        <Border Grid.Column="1" Background="{DynamicResource Brush.Accent.Soft}" CornerRadius="10" Padding="9,4" VerticalAlignment="Center">
                            <TextBlock Text="{Binding SelectedCount, StringFormat='{}{0} yapı'}" FontWeight="SemiBold" FontSize="10.5"
                                       Foreground="{DynamicResource Brush.Accent}" />
                        </Border>
                    </Grid>

                    <TextBlock Text="Henüz yapı seçilmedi. Yukarıdaki sayfalara tıkladığınız sırada bloklar burada oluşur."
                               Margin="8,12" TextAlignment="Center" TextWrapping="Wrap"
                               Foreground="{DynamicResource Brush.Text.Secondary}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedCount}" Value="0">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <ItemsControl ItemsSource="{Binding OrderedSelectedSheets}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#FFCAD8EE" BorderThickness="1" Background="#FFFAFCFF"
                                        CornerRadius="10" Padding="11" Margin="0,0,0,9">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,9">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border Width="32" Height="32" CornerRadius="9" Background="{DynamicResource Brush.Accent.Soft}">
                                                <TextBlock Text="{Binding SelectionOrderText}" FontWeight="Bold" Foreground="{DynamicResource Brush.Accent}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="9,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding WorksheetName}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding WorkbookDisplayName}" FontSize="9.5"
                                                           Foreground="{DynamicResource Brush.Text.Secondary}" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Button Content="↑" Style="{StaticResource Btn.Mini}" Command="{Binding MoveEarlierCommand}"
                                                        Width="30" Height="28" Margin="0,0,4,0" ToolTip="Bu yapıyı öne taşı" />
                                                <Button Content="↓" Style="{StaticResource Btn.Mini}" Command="{Binding MoveLaterCommand}"
                                                        Width="30" Height="28" ToolTip="Bu yapıyı arkaya taşı" />
                                            </StackPanel>
                                        </Grid>

                                        <Grid Margin="12,0,0,7">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="92" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Content="Başlık" IsChecked="{Binding IncludeHeading, Mode=TwoWay}"
                                                      VerticalAlignment="Center" FontWeight="SemiBold" />
                                            <TextBox Grid.Column="1" Text="{Binding HeadingText, UpdateSourceTrigger=PropertyChanged}"
                                                     IsEnabled="{Binding IncludeHeading}" />
                                        </Grid>

                                        <Grid Margin="28,0,0,7">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="92" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Content="Alt Başlık" IsChecked="{Binding IncludeAltHeading, Mode=TwoWay}"
                                                      VerticalAlignment="Center" FontWeight="SemiBold" />
                                            <TextBox Grid.Column="1" Text="{Binding AltHeadingText, UpdateSourceTrigger=PropertyChanged}"
                                                     IsEnabled="{Binding IncludeAltHeading}" />
                                        </Grid>

                                        <Grid Margin="44,0,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="76" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Tablo" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <TextBox Grid.Column="1" Text="{Binding TableName, UpdateSourceTrigger=PropertyChanged}" />
                                        </Grid>

                                        <TextBlock Text="{Binding LastResultText}" Margin="44,7,0,0" FontSize="9.5"
                                                   Foreground="{DynamicResource Brush.Text.Secondary}"
                                                   Visibility="{Binding LastResultText, Converter={StaticResource StringToVisibility}}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2" Margin="0,12,0,0" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
                <ProgressBar Height="8" Minimum="0" Maximum="100" Value="{Binding ProgressPercent, Mode=OneWay}" />
                <TextBlock Text="{Binding CurrentItemText}" Margin="0,6,0,0" FontSize="10.5"
                           Foreground="{DynamicResource Brush.Text.Secondary}" TextWrapping="Wrap" />
            </StackPanel>

            <Grid Grid.Row="3" Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{Binding StatusText}" FontSize="10.5" Foreground="{DynamicResource Brush.Text.Secondary}" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding SelectedCount, StringFormat='{}{0} yapı seçildi'}" Margin="0,3,0,0" FontWeight="SemiBold" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Content="İptal" Style="{StaticResource Btn.Mini}" Command="{Binding CancelTransferSelectedCommand}"
                            Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}" Margin="0,0,8,0" />
                    <Button Content="Rapor Yapısını Oluştur" Style="{StaticResource Btn.Primary}"
                            Command="{Binding TransferSelectedCommand}" Height="34" Padding="17,0" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>