<UserControl x:Class="KKL.WordStudio.UI.Views.LoadedSourcesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="330">
    <Grid VerticalAlignment="Center">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="0"
                   Text="Yüklenen Kaynaklar"
                   FontSize="10.5"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource Brush.Text.Secondary}"
                   VerticalAlignment="Center"
                   Margin="0,0,8,0" />

        <Grid Grid.Column="1">
            <ComboBox ItemsSource="{Binding OpenWorkbooks}"
                      SelectedItem="{Binding SelectedWorkbook, Mode=TwoWay}"
                      MinWidth="190"
                      MaxWidth="270"
                      Height="32"
                      Padding="8,0"
                      ToolTip="Yüklenen Excel kaynakları arasında geçiş yapın">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <DockPanel LastChildFill="True" ToolTip="{Binding FilePath}">
                            <TextBlock DockPanel.Dock="Right"
                                       Text="{Binding SheetNames.Count, StringFormat={}  {0} sayfa}"
                                       FontSize="10"
                                       Foreground="{DynamicResource Brush.Text.Secondary}"
                                       Margin="10,0,0,0"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding DisplayName}"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center" />
                        </DockPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <TextBlock Text="Henüz Excel kaynağı yok"
                       FontSize="11"
                       Foreground="{DynamicResource Brush.Text.Secondary}"
                       VerticalAlignment="Center"
                       Margin="10,0"
                       IsHitTestVisible="False"
                       Visibility="{Binding HasOpenWorkbook, Converter={StaticResource InverseBoolToVisibility}}" />
        </Grid>

        <Button Grid.Column="2"
                Content="＋"
                Style="{StaticResource Btn.Mini}"
                Command="{Binding OpenExcelFileCommand}"
                Width="32"
                Height="32"
                Margin="6,0,0,0"
                ToolTip="Excel kaynağı ekle" />
    </Grid>
</UserControl>
