<UserControl x:Class="KKL.WordStudio.UI.Views.ContentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:KKL.WordStudio.UI.ViewModels">
    <UserControl.Resources>
        <HierarchicalDataTemplate DataType="{x:Type vm:ContentsNodeViewModel}" ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <Ellipse Width="7" Height="7" Margin="0,0,8,0" VerticalAlignment="Center"
                         Visibility="{Binding Kind, Converter={StaticResource IsTableToVisibility}}"
                         Fill="{Binding BindingStatus, Converter={StaticResource BindingStatusToBrush}}" />
                <StackPanel>
                    <Grid>
                        <TextBlock x:Name="NameText" Text="{Binding DisplayName}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Kind}" Value="Heading">
                                            <Setter Property="FontWeight" Value="Bold" />
                                        </DataTrigger>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsSelected}" Value="True" />
                                                <Condition Binding="{Binding DataContext.IsRenaming, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBox x:Name="RenameBox"
                                 Text="{Binding DataContext.RenameText, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}"
                                 LostFocus="RenameBox_LostFocus">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsSelected}" Value="True" />
                                                <Condition Binding="{Binding DataContext.IsRenaming, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding DataContext.CommitStructuredRenameCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                <KeyBinding Key="Esc" Command="{Binding DataContext.CancelRenameCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                            </TextBox.InputBindings>
                        </TextBox>
                    </Grid>
                    <TextBlock Text="{Binding StatusText}" FontSize="10" Foreground="#FF7B8798" Margin="0,1,0,0"
                               Visibility="{Binding Kind, Converter={StaticResource IsTableToVisibility}}" />
                </StackPanel>
            </StackPanel>
        </HierarchicalDataTemplate>
    </UserControl.Resources>

    <DockPanel>
        <WrapPanel DockPanel.Dock="Top" Margin="10,10,10,6">
            <Button Content="+ Başlık" Style="{StaticResource Btn.Mini}" Command="{Binding AddStructuredHeadingCommand}" Margin="0,0,6,6" />
            <Button Content="+ Alt Başlık" Style="{StaticResource Btn.Mini}" Command="{Binding AddStructuredAltHeadingCommand}" Margin="0,0,6,6" />
            <Button Content="+ Tablo" Style="{StaticResource Btn.Mini}" Command="{Binding AddStructuredTableCommand}" Margin="0,0,6,6" />
            <Button Content="+ Üst Bilgi" Style="{StaticResource Btn.Mini}" Command="{Binding AddHeaderTextCommand}" Margin="0,0,6,6" />
            <Button Content="+ Alt Bilgi" Style="{StaticResource Btn.Mini}" Command="{Binding AddFooterTextCommand}" Margin="0,0,6,6" />
        </WrapPanel>
        <CheckBox DockPanel.Dock="Top" Content="İçindekiler Tablosu" IsChecked="{Binding IncludeTableOfContents}" Margin="12,0,10,8" />

        <Border DockPanel.Dock="Bottom" Margin="10,6,10,10" Padding="11,10" CornerRadius="9"
                Background="{DynamicResource Brush.Soft}" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1"
                Visibility="{Binding HasSelection, Converter={StaticResource BoolToVisibility}}">
            <StackPanel>
                <TextBlock Text="{Binding SelectedTitle}" FontWeight="SemiBold" />
                <TextBlock Text="{Binding SelectedSubtitle}" Foreground="{DynamicResource Brush.Text.Secondary}" FontSize="11" Margin="0,4,0,7" TextWrapping="Wrap" />

                <WrapPanel Margin="0,0,0,4">
                    <Button Content="Yeniden Adlandır" Style="{StaticResource Btn.Mini}" Command="{Binding BeginRenameCommand}" Margin="0,0,6,6" />
                    <Button Content="Sil" Style="{StaticResource Btn.Mini}" Command="{Binding DeleteStructuredSelectedCommand}" Margin="0,0,6,6" />
                    <Button Content="Yukarı" Style="{StaticResource Btn.Mini}" Command="{Binding MoveStructuredUpCommand}" Margin="0,0,6,6" />
                    <Button Content="Aşağı" Style="{StaticResource Btn.Mini}" Command="{Binding MoveStructuredDownCommand}" Margin="0,0,6,6" />
                    <Button Content="Girintiyi Artır" Style="{StaticResource Btn.Mini}" Command="{Binding IndentStructuredCommand}" Margin="0,0,6,6" />
                    <Button Content="Girintiyi Azalt" Style="{StaticResource Btn.Mini}" Command="{Binding OutdentStructuredCommand}" Margin="0,0,6,6" />
                </WrapPanel>

                <TextBlock Text="{Binding StatusMessage}" FontSize="11" Foreground="#FFB4553C" TextWrapping="Wrap"
                           Margin="0,0,0,6"
                           Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibility}}" />

                <Button Content="Özellikleri Düzenle" Style="{StaticResource Btn.Link}" Command="{Binding EditPropertiesCommand}" />
            </StackPanel>
        </Border>

        <TreeView x:Name="Tree" ItemsSource="{Binding StructuredRootNodes}" BorderThickness="0" Background="Transparent"
                  SelectedItemChanged="Tree_SelectedItemChanged" Margin="4,0"
                  AllowDrop="True"
                  PreviewMouseLeftButtonDown="Tree_PreviewMouseLeftButtonDown"
                  MouseMove="Tree_MouseMove"
                  DragOver="Tree_DragOver"
                  DragLeave="Tree_DragLeave"
                  Drop="Tree_Drop">
            <TreeView.InputBindings>
                <KeyBinding Key="F2" Command="{Binding BeginRenameCommand}" />
                <KeyBinding Key="Delete" Command="{Binding DeleteStructuredSelectedCommand}" />
            </TreeView.InputBindings>
            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem">
                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                    <Setter Property="IsExpanded" Value="True" />
                    <Setter Property="Padding" Value="2" />
                </Style>
            </TreeView.ItemContainerStyle>
        </TreeView>
    </DockPanel>
</UserControl>
