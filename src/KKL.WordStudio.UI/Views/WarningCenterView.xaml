<UserControl x:Class="KKL.WordStudio.UI.Views.WarningCenterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{DynamicResource Brush.Surface.Alt}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="14,14,14,8" Padding="12" CornerRadius="10"
                Background="#FFFFF8E7" BorderBrush="#FFF4D68A" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Width="30" Height="30" CornerRadius="8" Background="#FFFFE8A8" VerticalAlignment="Top">
                    <TextBlock Text="!" FontSize="16" FontWeight="Bold" Foreground="#FF9A6700"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <TextBlock Text="{Binding HeaderText}" FontSize="12.5" FontWeight="SemiBold"
                               Foreground="{DynamicResource Brush.Text.Primary}" />
                    <TextBlock Text="Tekrarlanan kayıtlar tek aksiyon altında gruplanır. Bir kayda tıklayarak rapor öğesine ve kaynağa gidin."
                               FontSize="10" Foreground="{DynamicResource Brush.Text.Secondary}"
                               TextWrapping="Wrap" Margin="0,3,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="12,0,12,9" Background="White" BorderBrush="{DynamicResource Brush.Border.Light}"
                BorderThickness="1" CornerRadius="9" Padding="5">
            <WrapPanel>
                <Button Content="{Binding TotalCount, StringFormat=Tümü ({0})}" Style="{StaticResource Btn.Mini}"
                        Command="{Binding ShowAllCommand}" Margin="0,0,4,0" />
                <Button Content="{Binding ErrorCount, StringFormat=Hata ({0})}" Style="{StaticResource Btn.Mini}"
                        Command="{Binding ShowErrorsCommand}" Margin="0,0,4,0" />
                <Button Content="{Binding WarningCount, StringFormat=Uyarı ({0})}" Style="{StaticResource Btn.Mini}"
                        Command="{Binding ShowWarningsCommand}" Margin="0,0,4,0" />
                <Button Content="{Binding InformationCount, StringFormat=Bilgi ({0})}" Style="{StaticResource Btn.Mini}"
                        Command="{Binding ShowInformationCommand}" />
            </WrapPanel>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <Grid>
                <ItemsControl ItemsSource="{Binding Items}" Margin="12,0,12,12"
                              Visibility="{Binding HasItems, Converter={StaticResource BoolToVisibility}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    IsEnabled="{Binding CanNavigate}"
                                    HorizontalContentAlignment="Stretch"
                                    Background="Transparent" BorderThickness="0" Padding="0"
                                    Margin="0,0,0,8" Cursor="Hand">
                                <Border Background="White" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1"
                                        CornerRadius="10" Padding="11">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="4" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Background="{Binding SeverityBrush}" CornerRadius="3" />

                                        <StackPanel Grid.Column="1" Margin="10,0,9,0">
                                            <WrapPanel>
                                                <Border Background="#FFF1F5F9" CornerRadius="7" Padding="7,2" Margin="0,0,6,4">
                                                    <TextBlock Text="{Binding SeverityText}" FontSize="9" FontWeight="Bold" />
                                                </Border>
                                                <Border Background="#FFFFF2D7" CornerRadius="7" Padding="7,2" Margin="0,0,6,4"
                                                        Visibility="{Binding HasMultipleOccurrences, Converter={StaticResource BoolToVisibility}}">
                                                    <TextBlock Text="{Binding OccurrenceText}" FontSize="9" FontWeight="SemiBold" Foreground="#FF8A5A00" />
                                                </Border>
                                            </WrapPanel>

                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="11.5"
                                                       Foreground="{DynamicResource Brush.Text.Primary}" />
                                            <TextBlock Text="{Binding Message}" TextWrapping="Wrap" FontSize="10.2"
                                                       Foreground="{DynamicResource Brush.Text.Secondary}" Margin="0,4,0,0" />

                                            <WrapPanel Margin="0,8,0,0">
                                                <Border Background="#FFF1F5F9" CornerRadius="7" Padding="7,3" Margin="0,0,5,4"
                                                        Visibility="{Binding HasElementName, Converter={StaticResource BoolToVisibility}}">
                                                    <TextBlock Text="{Binding ElementName}" FontSize="9.5" FontWeight="SemiBold" />
                                                </Border>
                                                <Border Background="#FFEAF1FF" CornerRadius="7" Padding="7,3" Margin="0,0,5,4"
                                                        Visibility="{Binding HasKey, Converter={StaticResource BoolToVisibility}}">
                                                    <TextBlock Text="{Binding KeyText}" FontSize="9.5" Foreground="{DynamicResource Brush.Accent}" />
                                                </Border>
                                            </WrapPanel>

                                            <TextBlock Text="{Binding SourceText}" FontSize="9.3"
                                                       Foreground="{DynamicResource Brush.Text.Secondary}"
                                                       TextWrapping="Wrap" Margin="0,2,0,0"
                                                       Visibility="{Binding HasSource, Converter={StaticResource BoolToVisibility}}" />
                                        </StackPanel>

                                        <TextBlock Grid.Column="2" Text="›" FontSize="18" Foreground="#FF8793A4"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="24"
                            Visibility="{Binding HasItems, Converter={StaticResource InverseBoolToVisibility}}">
                    <Border Width="44" Height="44" CornerRadius="12" Background="#FFEAF7EF">
                        <TextBlock Text="✓" FontSize="20" Foreground="#FF2F855A"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Bu filtrede kayıt yok" FontSize="13" FontWeight="SemiBold" Margin="0,10,0,0"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Diğer seviyeleri görmek için üstteki filtreleri kullanın."
                               FontSize="10" Foreground="{DynamicResource Brush.Text.Secondary}"
                               TextAlignment="Center" TextWrapping="Wrap" Margin="0,4,0,0" />
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <TextBlock Grid.Row="3" Text="{Binding NavigationStatusText}" Margin="14,6,14,12"
                   FontSize="9.8" Foreground="{DynamicResource Brush.Text.Secondary}" TextWrapping="Wrap" />
    </Grid>
</UserControl>
