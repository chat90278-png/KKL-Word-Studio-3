<UserControl x:Class="KKL.WordStudio.UI.Views.WarningCenterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{DynamicResource Brush.Surface.Alt}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="14,14,14,8" Padding="12" CornerRadius="10"
                Background="{Binding HeaderBackground}"
                BorderBrush="{Binding HeaderBorderBrush}" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Width="30" Height="30" CornerRadius="8"
                        Background="{Binding HeaderIconBackground}" VerticalAlignment="Top">
                    <TextBlock Text="{Binding HeaderIcon}" FontSize="16" FontWeight="Bold"
                               Foreground="{Binding HeaderIconBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <TextBlock Text="{Binding HeaderText}" FontSize="12.5" FontWeight="SemiBold"
                               Foreground="{DynamicResource Brush.Text.Primary}" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding HeaderDetailText}"
                               FontSize="10" Foreground="{DynamicResource Brush.Text.Secondary}"
                               TextWrapping="Wrap" Margin="0,3,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="12,0,12,9" Background="White"
                BorderBrush="{DynamicResource Brush.Border.Light}"
                BorderThickness="1" CornerRadius="9" Padding="5">
            <WrapPanel>
                <Button Style="{StaticResource Btn.Mini}" Command="{Binding ShowAllCommand}" Margin="0,0,4,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Tümü" />
                        <Border Background="#FFEAF1FF" CornerRadius="6" Padding="5,1" Margin="5,0,0,0">
                            <TextBlock Text="{Binding TotalCount}" FontSize="9" FontWeight="SemiBold"
                                       Foreground="{DynamicResource Brush.Accent}" />
                        </Border>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource Btn.Mini}" Command="{Binding ShowErrorsCommand}" Margin="0,0,4,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Hata" />
                        <Border Background="#FFFFE9E7" CornerRadius="6" Padding="5,1" Margin="5,0,0,0">
                            <TextBlock Text="{Binding ErrorCount}" FontSize="9" FontWeight="SemiBold" Foreground="#FFB42318" />
                        </Border>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource Btn.Mini}" Command="{Binding ShowWarningsCommand}" Margin="0,0,4,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Uyarı" />
                        <Border Background="#FFFFF2D7" CornerRadius="6" Padding="5,1" Margin="5,0,0,0">
                            <TextBlock Text="{Binding WarningCount}" FontSize="9" FontWeight="SemiBold" Foreground="#FF8A5A00" />
                        </Border>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource Btn.Mini}" Command="{Binding ShowInformationCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Bilgi" />
                        <Border Background="#FFEAF1FF" CornerRadius="6" Padding="5,1" Margin="5,0,0,0">
                            <TextBlock Text="{Binding InformationCount}" FontSize="9" FontWeight="SemiBold"
                                       Foreground="#FF326FA8" />
                        </Border>
                    </StackPanel>
                </Button>
            </WrapPanel>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <Grid>
                <ItemsControl ItemsSource="{Binding Items}" Margin="12,0,12,12"
                              Visibility="{Binding HasItems, Converter={StaticResource BoolToVisibility}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" BorderBrush="{DynamicResource Brush.Border}"
                                    BorderThickness="1" CornerRadius="10" Padding="11" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="4" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Background="{Binding SeverityBrush}" CornerRadius="3" />

                                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                        <WrapPanel>
                                            <Border Background="#FFF1F5F9" CornerRadius="7" Padding="7,2" Margin="0,0,6,4">
                                                <TextBlock Text="{Binding SeverityText}" FontSize="9" FontWeight="Bold" />
                                            </Border>
                                            <Border Background="#FFEAF1FF" CornerRadius="7" Padding="7,2" Margin="0,0,6,4">
                                                <TextBlock Text="{Binding CodeText}" FontSize="8.6" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource Brush.Accent}" />
                                            </Border>
                                            <Border Background="#FFFFF2D7" CornerRadius="7" Padding="7,2" Margin="0,0,6,4"
                                                    Visibility="{Binding HasMultipleOccurrences, Converter={StaticResource BoolToVisibility}}">
                                                <TextBlock Text="{Binding OccurrenceText}" FontSize="9" FontWeight="SemiBold"
                                                           Foreground="#FF8A5A00" />
                                            </Border>
                                        </WrapPanel>

                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="11.5"
                                                   Foreground="{DynamicResource Brush.Text.Primary}" />
                                        <TextBlock Text="{Binding Message}" TextWrapping="Wrap" FontSize="10.2"
                                                   Foreground="{DynamicResource Brush.Text.Secondary}" Margin="0,4,0,0" />

                                        <WrapPanel Margin="0,8,0,0">
                                            <Border Background="#FFF1F5F9" CornerRadius="7" Padding="7,3" Margin="0,0,5,4"
                                                    Visibility="{Binding HasElementName, Converter={StaticResource BoolToVisibility}}">
                                                <TextBlock Text="{Binding ElementName}" FontSize="9.5" FontWeight="SemiBold" />
                                            </Border>
                                            <Border Background="#FFF1F5F9" CornerRadius="7" Padding="7,3" Margin="0,0,5,4"
                                                    Visibility="{Binding HasAffectedColumn, Converter={StaticResource BoolToVisibility}}">
                                                <TextBlock Text="{Binding AffectedColumnText}" FontSize="9.3" />
                                            </Border>
                                            <Border Background="#FFF1F5F9" CornerRadius="7" Padding="7,3" Margin="0,0,5,4"
                                                    Visibility="{Binding HasAffectedRows, Converter={StaticResource BoolToVisibility}}">
                                                <TextBlock Text="{Binding AffectedRowsText}" FontSize="9.3" />
                                            </Border>
                                            <Border Background="#FFEAF1FF" CornerRadius="7" Padding="7,3" Margin="0,0,5,4"
                                                    Visibility="{Binding HasDistinctKeys, Converter={StaticResource BoolToVisibility}}">
                                                <TextBlock Text="{Binding DistinctKeyText}" FontSize="9.3"
                                                           Foreground="{DynamicResource Brush.Accent}" />
                                            </Border>
                                        </WrapPanel>

                                        <TextBlock Text="{Binding ExampleText}" FontSize="9.5"
                                                   Foreground="{DynamicResource Brush.Text.Primary}"
                                                   TextWrapping="Wrap" Margin="0,5,0,0"
                                                   Visibility="{Binding HasExamples, Converter={StaticResource BoolToVisibility}}" />

                                        <TextBlock Text="{Binding SourceText}" FontSize="9.3"
                                                   Foreground="{DynamicResource Brush.Text.Secondary}"
                                                   TextWrapping="Wrap" Margin="0,7,0,0"
                                                   Visibility="{Binding HasSource, Converter={StaticResource BoolToVisibility}}" />

                                        <WrapPanel Margin="0,10,0,0">
                                            <Button Content="{Binding PrimaryNavigationText}" Style="{StaticResource Btn.Mini}"
                                                    Command="{Binding DataContext.NavigateFirstCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}" IsEnabled="{Binding CanNavigate}" Margin="0,0,6,4" />
                                            <Button Content="Sonraki" Style="{StaticResource Btn.Mini}"
                                                    Command="{Binding DataContext.NavigateNextCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}" Margin="0,0,6,4"
                                                    Visibility="{Binding CanNavigateNext, Converter={StaticResource BoolToVisibility}}" />
                                            <Button Content="Tümünü Göster" Style="{StaticResource Btn.Mini}"
                                                    Command="{Binding DataContext.ShowAllOccurrencesCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}" Margin="0,0,0,4"
                                                    Visibility="{Binding HasMultipleOccurrences, Converter={StaticResource BoolToVisibility}}" />
                                        </WrapPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="24"
                            Visibility="{Binding HasItems, Converter={StaticResource InverseBoolToVisibility}}">
                    <Border Width="44" Height="44" CornerRadius="12" Background="#FFEAF7EF">
                        <TextBlock Text="✓" FontSize="20" Foreground="#FF2F855A"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Bu filtrede kayıt yok" FontSize="13" FontWeight="SemiBold" Margin="0,10,0,0"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Diğer seviyeleri görmek için üstteki filtreleri kullanın."
                               FontSize="10" Foreground="{DynamicResource Brush.Text.Secondary}"
                               TextAlignment="Center" TextWrapping="Wrap" Margin="0,4,0,0" />
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <TextBlock Grid.Row="3" Text="{Binding NavigationStatusText}" Margin="14,6,14,12"
                   FontSize="9.8" Foreground="{DynamicResource Brush.Text.Secondary}" TextWrapping="Wrap" />
    </Grid>
</UserControl>
