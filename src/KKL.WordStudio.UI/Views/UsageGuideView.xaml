<UserControl x:Class="KKL.WordStudio.UI.Views.UsageGuideView"
             x:Name="GuideRoot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource Brush.App.Background}"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <UserControl.Resources>
        <Style x:Key="GuideNavItem" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,5" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder" Background="{TemplateBinding Background}" CornerRadius="9" Padding="10,9">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#FFF1F5F9" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource Brush.Accent.Soft}" />
                                <Setter Property="Foreground" Value="{DynamicResource Brush.Accent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GuideDisplayPanel" TargetType="StackPanel">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GuideEditorPanel" TargetType="StackPanel">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="16" Padding="20,16" Background="#FF1D4ED8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="KKL Word Studio Kullanım Kılavuzu" Foreground="White" FontSize="22" FontWeight="Bold" />
                    <TextBlock Text="Meyveli demo veri üzerinden ekran bazlı, düzenlenebilir kullanım anlatımı"
                               Foreground="#FFDCEBFF" FontSize="11.5" Margin="0,5,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Düzenleme Modu" Command="{Binding BeginEditCommand}" Style="{StaticResource Btn.Mini}" Height="36" Padding="16,0" Margin="0,0,8,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource Btn.Mini}">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="Kaydet" Command="{Binding SaveEditsCommand}" Style="{StaticResource Btn.Mini}" Height="36" Padding="16,0" Margin="0,0,8,0"
                            Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibility}}" />
                    <Button Content="Vazgeç" Command="{Binding CancelEditsCommand}" Style="{StaticResource Btn.Mini}" Height="36" Padding="16,0" Margin="0,0,8,0"
                            Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibility}}" />
                    <Button x:Name="CloseGuideButton" Content="Çalışma Alanına Dön" Style="{StaticResource Btn.Mini}" Height="36" Padding="16,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource Btn.Mini}">
                                <Setter Property="IsEnabled" Value="True" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                        <Setter Property="IsEnabled" Value="False" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="285" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1" CornerRadius="14" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="BÖLÜMLER" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource Brush.Text.Secondary}" Margin="7,6,0,10" />
                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Sections}"
                             SelectedItem="{Binding SelectedSection, Mode=TwoWay}"
                             ItemContainerStyle="{StaticResource GuideNavItem}"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.Style>
                            <Style TargetType="ListBox">
                                <Setter Property="IsEnabled" Value="True" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                        <Setter Property="IsEnabled" Value="False" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.Style>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="27" Height="27" CornerRadius="7" Background="#FFF1F5F9">
                                        <TextBlock Text="{Binding Icon}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   FontFamily="Segoe UI Symbol" FontSize="13" FontWeight="SemiBold" />
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="{Binding Title}" VerticalAlignment="Center" FontSize="12"
                                               FontWeight="SemiBold" TextWrapping="Wrap" Margin="8,0,0,0" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="White" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1" CornerRadius="14">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="22">
                        <StackPanel Style="{StaticResource GuideDisplayPanel}" DataContext="{Binding SelectedSection}">
                            <TextBlock Text="{Binding Title}" FontSize="23" FontWeight="Bold" Foreground="#FF102A56" />
                            <TextBlock Text="Gerçek uygulama ekranı ve doğrulanmış kullanıcı akışı" FontSize="10.5"
                                       Foreground="{DynamicResource Brush.Text.Secondary}" Margin="0,4,0,14" />

                            <Border Background="#FFF8FAFD" BorderBrush="#FFD8E1ED" BorderThickness="1" CornerRadius="12" Padding="10">
                                <Image Source="{Binding ImageSource}"
                                       Stretch="Uniform"
                                       StretchDirection="DownOnly"
                                       MaxHeight="720"
                                       HorizontalAlignment="Center"
                                       SnapsToDevicePixels="True"
                                       RenderOptions.BitmapScalingMode="HighQuality" />
                            </Border>

                            <Border Background="White" BorderBrush="#FFE2E8F0" BorderThickness="1" CornerRadius="11" Padding="15,13" Margin="0,15,0,0">
                                <StackPanel>
                                    <TextBlock Text="Ne işe yarar?" FontSize="14" FontWeight="Bold" Foreground="#FF1E3A8A" />
                                    <TextBlock Text="{Binding Purpose}" FontSize="12" Foreground="#FF334155" TextWrapping="Wrap" Margin="0,6,0,0" LineHeight="19" />
                                </StackPanel>
                            </Border>

                            <Border Background="White" BorderBrush="#FFE2E8F0" BorderThickness="1" CornerRadius="11" Padding="15,13" Margin="0,11,0,0">
                                <StackPanel>
                                    <TextBlock Text="Adım adım kullanım" FontSize="14" FontWeight="Bold" Foreground="#FF14532D" />
                                    <ItemsControl ItemsSource="{Binding Actions}" Margin="0,5,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,4,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="17" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="•" FontWeight="Bold" Foreground="#FF0F766E" />
                                                    <TextBlock Grid.Column="1" Text="{Binding}" FontSize="12" Foreground="#FF334155" TextWrapping="Wrap" LineHeight="19" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Border Background="#FFFFFBEB" BorderBrush="#FFF6D68A" BorderThickness="1" CornerRadius="11" Padding="15,13" Margin="0,11,0,22">
                                <StackPanel>
                                    <TextBlock Text="İpucu / Dikkat" FontSize="14" FontWeight="Bold" Foreground="#FF9A3412" />
                                    <TextBlock Text="{Binding Tip}" FontSize="12" Foreground="#FF7C2D12" TextWrapping="Wrap" Margin="0,6,0,0" LineHeight="19" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Style="{StaticResource GuideEditorPanel}">
                            <TextBlock Text="Seçili Bölümü Düzenle" FontSize="23" FontWeight="Bold" Foreground="#FF102A56" />
                            <TextBlock Text="Değişiklikler yalnız bu Windows kullanıcısında saklanır; Excel ve rapor verisine dokunulmaz."
                                       Foreground="{DynamicResource Brush.Text.Secondary}" FontSize="10.5" Margin="0,4,0,14" />

                            <TextBlock Text="Bölüm başlığı" FontWeight="SemiBold" />
                            <TextBox Text="{Binding EditTitle, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,14" Padding="10,7" />

                            <TextBlock Text="Ekran görseli" FontWeight="SemiBold" />
                            <Border Background="#FFF8FAFD" BorderBrush="#FFD8E1ED" BorderThickness="1" CornerRadius="12" Padding="10" Margin="0,6,0,8">
                                <Image Source="{Binding EditImageSource}"
                                       Stretch="Uniform"
                                       StretchDirection="DownOnly"
                                       MaxHeight="620"
                                       HorizontalAlignment="Center"
                                       RenderOptions.BitmapScalingMode="HighQuality" />
                            </Border>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <Button Content="Görseli Değiştir" Command="{Binding ChooseImageCommand}" Style="{StaticResource Btn.Mini}" Margin="0,0,8,0" />
                                <Button Content="Varsayılan Görsel" Command="{Binding UseDefaultImageCommand}" Style="{StaticResource Btn.Mini}" />
                            </StackPanel>

                            <TextBlock Text="Ne işe yarar?" FontWeight="SemiBold" />
                            <TextBox Text="{Binding EditPurpose, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="86" Margin="0,6,0,14" Padding="10,7" />

                            <TextBlock Text="Adım adım kullanım — her adımı ayrı satıra yazın" FontWeight="SemiBold" />
                            <TextBox Text="{Binding EditActionsText, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="150" Margin="0,6,0,14" Padding="10,7" />

                            <TextBlock Text="İpucu / Dikkat" FontWeight="SemiBold" />
                            <TextBox Text="{Binding EditTip, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="86" Margin="0,6,0,12" Padding="10,7" />

                            <TextBlock Text="{Binding EditorStatusText}" TextWrapping="Wrap" Foreground="#FF475569" Margin="0,0,0,12" />
                            <Button Content="Seçili Bölümü Varsayılana Döndür" Command="{Binding ResetSectionCommand}"
                                    Style="{StaticResource Btn.Mini}" HorizontalAlignment="Left" Margin="0,0,0,22" />
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
