<UserControl x:Class="KKL.WordStudio.UI.Views.ExcelWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid AllowDrop="True"
          DragEnter="ExcelDropTarget_DragEnter"
          DragOver="ExcelDropTarget_DragOver"
          DragLeave="ExcelDropTarget_DragLeave"
          Drop="ExcelDropTarget_Drop">
        <DockPanel Background="{DynamicResource Brush.Surface.Alt}">

            <!-- Header: workbook · sheet + Map Columns -->
            <Border DockPanel.Dock="Top" Height="50" BorderBrush="{DynamicResource Brush.Border.Light}" BorderThickness="0,0,0,1">
                <Grid Margin="14,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="KAYNAK VERİ" FontSize="10" FontWeight="Bold" Foreground="#FF7B8798" />
                        <TextBlock FontSize="14" FontWeight="SemiBold" Margin="0,2,0,0">
                            <Run Text="{Binding SelectedWorkbook.DisplayName, FallbackValue='Açık dosya yok'}" />
                            <Run Text=" · " />
                            <Run Text="{Binding SelectedWorkbook.SelectedSheetName}" />
                        </TextBlock>
                    </StackPanel>
                    <Button Grid.Column="1" Content="Excel Dosyası Aç..." Style="{StaticResource Btn.Mini}" Command="{Binding OpenExcelFileCommand}" Margin="0,0,8,0" />
                    <Button Grid.Column="2" Content="Sütunları Eşle" Style="{StaticResource Btn.Mini}" Command="{Binding OpenMappingDrawerCommand}" Margin="0,0,8,0"
                            ToolTip="İsteğe bağlı: sütunları anlamsal alan adlarıyla eşleyin. Aktarım için gerekli değildir." />
                    <!-- Sprint 7: THE primary action of the Excel Workspace — transfers the
                         current sheet's configured range directly into the report design. -->
                    <Button Grid.Column="3" Content="Word'e Aktar →" Style="{StaticResource Btn.Primary}" Height="32" Padding="14,0"
                            Command="{Binding TransferToReportCommand}"
                            ToolTip="Etkin sayfanın yapılandırılmış veri aralığını rapora aktarır" />
                </Grid>
            </Border>

            <!-- Sprint 9 working-data commands. Gesture/clipboard routing stays in
                 this view; every mutation is delegated to the ViewModel/Application service. -->
            <Border DockPanel.Dock="Top" Height="38" Background="White" BorderBrush="{DynamicResource Brush.Border.Light}" BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal" Margin="12,0" VerticalAlignment="Center">
                    <Border Style="{StaticResource Chip}" Margin="0,0,10,0">
                        <TextBlock Style="{StaticResource Chip.Text}" Text="{Binding WorkingDataStateText}" />
                    </Border>
                    <Button Content="Temizle" Style="{StaticResource Btn.Mini}" Click="ClearCells_Click" Margin="0,0,6,0" />
                    <Button Content="Kopyala" Style="{StaticResource Btn.Mini}" Click="Copy_Click" Margin="0,0,6,0" />
                    <Button Content="Yapıştır" Style="{StaticResource Btn.Mini}" Click="Paste_Click" Margin="0,0,10,0" />
                    <Button Content="Geri Al" Style="{StaticResource Btn.Mini}" Command="{Binding UndoCommand}" IsEnabled="{Binding CanUndo}" Margin="0,0,6,0" />
                    <Button Content="Yinele" Style="{StaticResource Btn.Mini}" Command="{Binding RedoCommand}" IsEnabled="{Binding CanRedo}" Margin="0,0,12,0" />
                    <Button Content="Kaynak Veriye Dön" Style="{StaticResource Btn.Mini}" Command="{Binding ResetToSourceCommand}"
                            IsEnabled="{Binding CanResetWorkingData}" ToolTip="Proje çalışma verisini bırakıp özgün Excel kaynağına döner" />
                </StackPanel>
            </Border>

            <!-- Range status strip: normal flow shows the detected/configured range, not raw technical fields. -->
            <Border DockPanel.Dock="Bottom" Height="38" Background="{DynamicResource Brush.Surface.Alt}" BorderBrush="{DynamicResource Brush.Border.Light}" BorderThickness="0,1,0,0">
                <Grid Margin="13,0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" FontWeight="Bold" Text="{Binding RangeStatusText}" VerticalAlignment="Center" Margin="0,0,12,0" />
                    <Button Grid.Column="1" Content="Veri Aralığını Düzenle" Style="{StaticResource Btn.Mini}" Command="{Binding OpenRangeEditorCommand}" Margin="0,0,14,0" />
                    <TextBlock Grid.Column="2" Text="{Binding StatusText}" Foreground="{DynamicResource Brush.Text.Secondary}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                </Grid>
            </Border>

            <!-- Sheet tabs -->
            <Border DockPanel.Dock="Bottom" Height="40" Background="{DynamicResource Brush.Soft}" BorderBrush="{DynamicResource Brush.Border.Light}" BorderThickness="0,1,0,0">
                <ItemsControl ItemsSource="{Binding SelectedWorkbook.SheetNames}" Margin="6,4,0,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding}" Padding="16,0" Height="32"
                                    Command="{Binding DataContext.SelectSheetTabCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource Btn.Base}" />
                                </Button.Style>
                                <Button.Background>
                                    <MultiBinding Converter="{StaticResource ActiveSheetBackground}">
                                        <Binding />
                                        <Binding Path="DataContext.SelectedWorkbook.SelectedSheetName" RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                                    </MultiBinding>
                                </Button.Background>
                                <Button.Foreground>
                                    <MultiBinding Converter="{StaticResource ActiveSheetForeground}">
                                        <Binding />
                                        <Binding Path="DataContext.SelectedWorkbook.SelectedSheetName" RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                                    </MultiBinding>
                                </Button.Foreground>
                                <Button.FontWeight>
                                    <MultiBinding Converter="{StaticResource ActiveSheetFontWeight}">
                                        <Binding />
                                        <Binding Path="DataContext.SelectedWorkbook.SelectedSheetName" RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                                    </MultiBinding>
                                </Button.FontWeight>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <!-- The grid itself IS the working surface. Sprint 8 adds an honest
                 empty-state/drop target without creating a second import path. -->
            <Grid>
                <DataGrid x:Name="WorkingDataGrid" ItemsSource="{Binding PreviewTable}" AutoGenerateColumns="True" IsReadOnly="False"
                          HeadersVisibility="All" RowHeaderWidth="48" CanUserAddRows="False" CanUserResizeRows="False" SelectionMode="Extended" SelectionUnit="CellOrRowHeader"
                          AutoGeneratingColumn="WorkingDataGrid_AutoGeneratingColumn" CellEditEnding="WorkingDataGrid_CellEditEnding"
                          PreviewKeyDown="WorkingDataGrid_PreviewKeyDown"
                          Visibility="{Binding HasOpenWorkbook, Converter={StaticResource BoolToVisibility}}">
                    <DataGrid.RowHeaderStyle>
                        <Style TargetType="DataGridRowHeader">
                            <Setter Property="Content" Value="{Binding [#]}" />
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="RowHeader_PreviewMouseLeftButtonDown" />
                            <EventSetter Event="PreviewMouseRightButtonDown" Handler="RowHeader_PreviewMouseRightButtonDown" />
                        </Style>
                    </DataGrid.RowHeaderStyle>
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="ColumnHeader_PreviewMouseLeftButtonDown" />
                            <EventSetter Event="PreviewMouseRightButtonDown" Handler="ColumnHeader_PreviewMouseRightButtonDown" />
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="Cell_PreviewMouseLeftButtonDown" />
                            <EventSetter Event="PreviewMouseRightButtonDown" Handler="Cell_PreviewMouseRightButtonDown" />
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                            <Setter Property="Background">
                                <Setter.Value>
                                    <MultiBinding Converter="{StaticResource HeaderRowBackground}">
                                        <Binding Path="[#]" />
                                        <Binding Path="DataContext.HeaderRowNumber" RelativeSource="{RelativeSource AncestorType=DataGrid}" />
                                    </MultiBinding>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="BorderThickness">
                                <Setter.Value>
                                    <MultiBinding Converter="{StaticResource RangeBoundaryThickness}">
                                        <Binding Path="[#]" />
                                        <Binding Path="DataContext.EffectiveDataStartRow" RelativeSource="{RelativeSource AncestorType=DataGrid}" />
                                        <Binding Path="DataContext.DetectedDataEndRow" RelativeSource="{RelativeSource AncestorType=DataGrid}" />
                                    </MultiBinding>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.RowStyle>
                </DataGrid>

                <Border Margin="22" CornerRadius="14"
                        Visibility="{Binding HasOpenWorkbook, Converter={StaticResource InverseBoolToVisibility}}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
                            <Setter Property="BorderThickness" Value="1" />
                            <Setter Property="Background" Value="White" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsExcelDropActive}" Value="True">
                                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                                    <Setter Property="BorderThickness" Value="2" />
                                    <Setter Property="Background" Value="{DynamicResource Brush.Accent.Soft}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="330">
                        <TextBlock Text="Excel dosyasını buraya sürükleyip bırakın" FontSize="16" FontWeight="SemiBold"
                                   TextAlignment="Center" TextWrapping="Wrap" />
                        <TextBlock Text=".xlsx ve .xlsm · kaynak dosya değiştirilmez" Margin="0,7,0,16"
                                   Foreground="{DynamicResource Brush.Text.Secondary}" TextAlignment="Center" />
                        <Button Content="veya Excel Dosyası Aç" Style="{StaticResource Btn.Primary}"
                                Command="{Binding OpenExcelFileCommand}" HorizontalAlignment="Center" Padding="16,0" Height="32" />
                    </StackPanel>
                </Border>
            </Grid>
        </DockPanel>

        <!-- ============ Sprint 13: compact range editor ============ -->
        <Border Background="#38141D2B" Visibility="{Binding IsRangeEditorOpen, Converter={StaticResource BoolToVisibility}}" />
        <Border HorizontalAlignment="Center" VerticalAlignment="Center" Width="410"
                Background="White" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1" CornerRadius="12"
                Visibility="{Binding IsRangeEditorOpen, Converter={StaticResource BoolToVisibility}}">
            <StackPanel Margin="18">
                <TextBlock Text="VERİ ARALIĞINI DÜZENLE" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource Brush.Text.Secondary}" Margin="0,0,0,12" />
                <CheckBox Content="Başlık satırı var" IsChecked="{Binding EditorHasHeader}" Margin="0,0,0,10" />
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="Başlık satırı" FontSize="10.5" Foreground="{DynamicResource Brush.Text.Secondary}" />
                        <TextBox Text="{Binding EditorHeaderRow, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding EditorHasHeader}" Margin="0,3,0,8" />
                        <TextBlock Text="Veri başlangıcı" FontSize="10.5" Foreground="{DynamicResource Brush.Text.Secondary}" />
                        <TextBox Text="{Binding EditorDataStartRow, UpdateSourceTrigger=PropertyChanged}" Margin="0,3,0,8" />
                        <TextBlock Text="Başlangıç sütunu" FontSize="10.5" Foreground="{DynamicResource Brush.Text.Secondary}" />
                        <TextBox Text="{Binding EditorStartColumn, UpdateSourceTrigger=PropertyChanged}" Margin="0,3,0,8" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <TextBlock Text="Veri bitişi" FontSize="10.5" Foreground="{DynamicResource Brush.Text.Secondary}" />
                        <TextBox Text="{Binding EditorDataEndRow, UpdateSourceTrigger=PropertyChanged}" Margin="0,3,0,8" />
                        <TextBlock Text="Bitiş sütunu" FontSize="10.5" Foreground="{DynamicResource Brush.Text.Secondary}" />
                        <TextBox Text="{Binding EditorEndColumn, UpdateSourceTrigger=PropertyChanged}" Margin="0,3,0,8" />
                    </StackPanel>
                </Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                    <Button Content="Yeniden Algıla" Style="{StaticResource Btn.Mini}" Command="{Binding RedetectRangeCommand}" Margin="0,0,8,0" />
                    <Button Content="İptal" Style="{StaticResource Btn.Mini}" Command="{Binding CancelRangeEditorCommand}" Margin="0,0,8,0" />
                    <Button Content="Uygula" Style="{StaticResource Btn.Primary}" Command="{Binding ApplyRangeEditorCommand}" Padding="14,0" Height="32" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ============ Column Mapping drawer (Excel-side, not the right dock) ============ -->
        <Border Background="#38141D2B" Visibility="{Binding IsMappingDrawerOpen, Converter={StaticResource BoolToVisibility}}"
                MouseLeftButtonUp="DrawerScrim_MouseLeftButtonUp" />
        <Border HorizontalAlignment="Left" VerticalAlignment="Stretch" Width="440" Margin="16"
                Background="White" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1" CornerRadius="12"
                Visibility="{Binding IsMappingDrawerOpen, Converter={StaticResource BoolToVisibility}}">
            <Border.Effect>
                <DropShadowEffect Color="#FF1E2A3D" Direction="270" ShadowDepth="8" BlurRadius="28" Opacity="0.2" />
            </Border.Effect>
            <DockPanel>
                <Border DockPanel.Dock="Top" Padding="16" BorderBrush="{DynamicResource Brush.Border.Light}" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="SÜTUN EŞLEME (İSTEĞE BAĞLI)" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource Brush.Text.Secondary}" />
                        <TextBlock Text="{Binding SelectedWorkbook.SelectedSheetName, StringFormat='{}{0} — anlamsal alanlar'}" FontSize="14" FontWeight="SemiBold" Margin="0,3,0,0" />
                    </StackPanel>
                </Border>

                <Border DockPanel.Dock="Bottom" BorderBrush="{DynamicResource Brush.Border.Light}" BorderThickness="0,1,0,0" Padding="14,10">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="İptal" Style="{StaticResource Btn.Mini}" Command="{Binding CancelMappingCommand}" Margin="0,0,8,0" />
                        <Button Content="Eşlemeyi Uygula" Style="{StaticResource Btn.Primary}" Command="{Binding ApplyMappingCommand}" Padding="14,0" Height="32" />
                    </StackPanel>
                </Border>

                <StackPanel DockPanel.Dock="Top" Margin="16,12,16,0">
                    <TextBlock Text="Veri kaynağı adı" FontSize="10.5" Foreground="{DynamicResource Brush.Text.Secondary}" Margin="0,0,0,4" />
                    <TextBox Text="{Binding DataSourceName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" />
                </StackPanel>

                <DataGrid Margin="10" ItemsSource="{Binding ColumnMappings}" AutoGenerateColumns="False" CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Excel Sütunu" Binding="{Binding SourceColumn}" IsReadOnly="True" Width="90" />
                        <DataGridTextColumn Header="Anlamsal Alan" Binding="{Binding FieldName}" Width="*" />
                        <DataGridTextColumn Header="Tür" Binding="{Binding DataType}" Width="90" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

        <!-- ============ Sprint 7: transfer decision flyout ============
             Shown only when "Word'e Aktar" targets a table that is already
             configured (bound and/or user-customized columns). A configured
             table is never silently overwritten — the user picks explicitly. -->
        <Border Background="#38141D2B" Visibility="{Binding IsTransferChoiceOpen, Converter={StaticResource BoolToVisibility}}"
                MouseLeftButtonUp="TransferChoiceScrim_MouseLeftButtonUp" />
        <Border HorizontalAlignment="Center" VerticalAlignment="Center" Width="380"
                Background="White" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1" CornerRadius="12"
                Visibility="{Binding IsTransferChoiceOpen, Converter={StaticResource BoolToVisibility}}">
            <Border.Effect>
                <DropShadowEffect Color="#FF1E2A3D" Direction="270" ShadowDepth="8" BlurRadius="28" Opacity="0.2" />
            </Border.Effect>
            <StackPanel Margin="18">
                <TextBlock Text="WORD'E AKTAR" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource Brush.Text.Secondary}" />
                <TextBlock FontSize="13" Margin="0,8,0,2" TextWrapping="Wrap">
                    <Run Text="'" /><Run Text="{Binding TransferChoiceTableName}" FontWeight="SemiBold" /><Run Text="' tablosu zaten yapılandırılmış." />
                </TextBlock>
                <TextBlock Text="Mevcut sütun yapısı korunsun mu, yoksa kaynaktan yenilensin mi?" FontSize="12"
                           Foreground="{DynamicResource Brush.Text.Secondary}" TextWrapping="Wrap" Margin="0,0,0,12" />
                <Button Content="Veriyi Yeniden Bağla (sütunları koru)" Style="{StaticResource Btn.Mini}" Height="32"
                        Command="{Binding TransferRebindKeepColumnsCommand}" Margin="0,0,0,8" HorizontalAlignment="Stretch" />
                <Button Content="Sütunları Kaynaktan Yenile ve Bağla" Style="{StaticResource Btn.Primary}" Height="32"
                        Command="{Binding TransferReplaceColumnsFromSourceCommand}" Margin="0,0,0,8" HorizontalAlignment="Stretch" />
                <Button Content="Kaynak Olarak Ekle" Style="{StaticResource Btn.Mini}" Height="32"
                        Command="{Binding TransferAddAsSourceCommand}" Margin="0,0,0,8" HorizontalAlignment="Stretch" />
                <Button Content="İptal" Style="{StaticResource Btn.Mini}" Height="30"
                        Command="{Binding CancelTransferChoiceCommand}" HorizontalAlignment="Right" Padding="14,0" />
            </StackPanel>
        </Border>


        <!-- Sprint 10: compact field matching surface, shown only when an
             additional source cannot be normalized safely by logical/header
             identity. No positional guessing is performed. -->
        <Border Background="#38141D2B" Visibility="{Binding IsSourceFieldMappingOpen, Converter={StaticResource BoolToVisibility}}"
                MouseLeftButtonUp="SourceFieldMappingScrim_MouseLeftButtonUp" />
        <Border HorizontalAlignment="Center" VerticalAlignment="Center" Width="460" MaxHeight="560"
                Background="White" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1" CornerRadius="12"
                Visibility="{Binding IsSourceFieldMappingOpen, Converter={StaticResource BoolToVisibility}}">
            <Border.Effect>
                <DropShadowEffect Color="#FF1E2A3D" Direction="270" ShadowDepth="8" BlurRadius="28" Opacity="0.2" />
            </Border.Effect>
            <DockPanel Margin="18">
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                    <TextBlock Text="KAYNAK ALAN EŞLEME" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource Brush.Text.Secondary}" />
                    <TextBlock FontSize="13" Margin="0,7,0,2" TextWrapping="Wrap">
                        <Run Text="'" /><Run Text="{Binding SourceFieldMappingTableName}" FontWeight="SemiBold" /><Run Text="' tablosuna eklenecek kaynağın alanlarını eşleyin." />
                    </TextBlock>
                    <TextBlock Text="Yalnızca çözülemeyen şemalarda gerekir; eşleme bu tablo kaynağıyla birlikte saklanır."
                               FontSize="11" Foreground="{DynamicResource Brush.Text.Secondary}" TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                    <Button Content="İptal" Style="{StaticResource Btn.Mini}" Command="{Binding CancelSourceFieldMappingCommand}" Margin="0,0,8,0" />
                    <Button Content="Kaynağı Ekle" Style="{StaticResource Btn.Primary}" Command="{Binding ApplySourceFieldMappingCommand}" Padding="14,0" Height="32" />
                </StackPanel>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding SourceFieldMappingRows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding TableColumnHeader}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,10,0" />
                                    <ComboBox Grid.Column="1" ItemsSource="{Binding AvailableSourceFields}"
                                              DisplayMemberPath="DisplayText" SelectedValuePath="SourceField"
                                              SelectedValue="{Binding SelectedSourceField, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
