<UserControl x:Class="KKL.WordStudio.UI.Views.PreviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:KKL.WordStudio.UI.ViewModels"
             xmlns:preview="clr-namespace:KKL.WordStudio.UI.Preview"
             Focusable="True"
             PreviewKeyDown="PreviewView_PreviewKeyDown">
    <UserControl.Resources>
        <!-- One visual contract for every positioned layout block. Selection
             follows the shared Workspace ElementId; drop feedback is gesture
             state only and never reorders the page/block collections. -->
        <Style x:Key="PageBlockContainer" TargetType="Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="2" />
            <Setter Property="ClipToBounds" Value="True" />
            <Setter Property="Focusable" Value="True" />
            <Setter Property="AllowDrop" Value="True" />
            <Setter Property="Cursor" Value="Hand" />
            <EventSetter Event="MouseLeftButtonDown" Handler="PageBlock_MouseLeftButtonDown" />
            <EventSetter Event="MouseMove" Handler="PageBlock_MouseMove" />
            <EventSetter Event="MouseRightButtonUp" Handler="PageBlock_MouseRightButtonUp" />
            <EventSetter Event="DragOver" Handler="PageBlock_DragOver" />
            <EventSetter Event="DragLeave" Handler="PageBlock_DragLeave" />
            <EventSetter Event="Drop" Handler="PageBlock_Drop" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding CanInteract}" Value="False">
                    <Setter Property="Cursor" Value="Arrow" />
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding CanInteract}" Value="True" />
                        <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsMouseOver}" Value="True" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="#0A2F6FEB" />
                    <Setter Property="BorderBrush" Value="#337EA6E8" />
                </MultiDataTrigger>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="#12E9F2FF" />
                    <Setter Property="BorderBrush" Value="#FF6F9FE8" />
                    <Setter Property="BorderThickness" Value="1.5" />
                </DataTrigger>
                <DataTrigger Binding="{Binding DropIndicator}" Value="Before">
                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                    <Setter Property="BorderThickness" Value="0,2.5,0,0" />
                    <Setter Property="Background" Value="#0C2F6FEB" />
                </DataTrigger>
                <DataTrigger Binding="{Binding DropIndicator}" Value="Into">
                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                    <Setter Property="BorderThickness" Value="2" />
                    <Setter Property="Background" Value="#182F6FEB" />
                </DataTrigger>
                <DataTrigger Binding="{Binding DropIndicator}" Value="After">
                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                    <Setter Property="BorderThickness" Value="0,0,0,2.5" />
                    <Setter Property="Background" Value="#0C2F6FEB" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <DataTemplate DataType="{x:Type vm:PreviewTextPageBlockViewModel}">
            <Border Style="{StaticResource PageBlockContainer}" Width="{Binding Width}" Height="{Binding Height}">
                <Grid Margin="2,0">
                    <preview:PreviewTextBlockControl Runs="{Binding Runs}"
                                                       TextAlignment="{Binding Alignment}"
                                                       FontFamily="{Binding FontFamily}"
                                                       FontSize="{Binding FontSize}"
                                                       FontWeight="{Binding FontWeight}"
                                                       FontStyle="{Binding FontStyle}"
                                                       TextDecorations="{Binding TextDecorations}"
                                                       Foreground="{Binding Foreground}"
                                                       LineHeight="{Binding LineHeight}"
                                                       LineStackingStrategy="BlockLineHeight"
                                                       FirstLineIndent="{Binding FirstLineIndent}"
                                                       VerticalAlignment="Top"
                                                       IsHitTestVisible="False"
                                                       Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisibility}}" />
                    <TextBox Text="{Binding EditText, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap"
                             AcceptsReturn="False"
                             VerticalAlignment="Stretch"
                             BorderBrush="#FF7EA6E8"
                             BorderThickness="1"
                             Padding="1"
                             Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}"
                             IsVisibleChanged="Editor_IsVisibleChanged"
                             KeyDown="TextEditor_KeyDown"
                             LostFocus="TextEditor_LostFocus" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:PreviewTablePageBlockViewModel}">
            <Border Style="{StaticResource PageBlockContainer}" Width="{Binding Width}" Height="{Binding Height}">
                <StackPanel Margin="2" ClipToBounds="True">
                    <Grid Margin="{Binding CaptionAreaMargin}"
                          Visibility="{Binding ShowCaptionArea, Converter={StaticResource BoolToVisibility}}"
                          MouseLeftButtonDown="TableCaption_MouseLeftButtonDown">
                        <Grid Visibility="{Binding IsCaptionEditing, Converter={StaticResource InverseBoolToVisibility}}">
                            <preview:PreviewTextBlockControl Runs="{Binding CaptionRuns}"
                                                               TextAlignment="{Binding CaptionAlignment}"
                                                               FontFamily="{Binding CaptionFontFamily}"
                                                               FontSize="{Binding CaptionFontSize}"
                                                               FontWeight="{Binding CaptionFontWeight}"
                                                               FontStyle="{Binding CaptionFontStyle}"
                                                               TextDecorations="{Binding CaptionTextDecorations}"
                                                               Foreground="{Binding CaptionForeground}"
                                                               LineHeight="{Binding CaptionLineHeight}"
                                                               LineStackingStrategy="BlockLineHeight"
                                                               FirstLineIndent="{Binding CaptionFirstLineIndent}"
                                                               TextWrapping="Wrap"
                                                               IsHitTestVisible="False"
                                                               Visibility="{Binding HasCaption, Converter={StaticResource BoolToVisibility}}" />
                            <TextBlock Text="Tablo başlığı eklemek için çift tıklayın"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       FontStyle="Italic"
                                       Foreground="#FF97A0AE"
                                       TextWrapping="Wrap"
                                       Visibility="{Binding HasCaption, Converter={StaticResource InverseBoolToVisibility}}" />
                        </Grid>
                        <TextBox Text="{Binding CaptionEditText, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="{Binding CaptionFontFamily}"
                                 FontSize="{Binding CaptionFontSize}"
                                 FontWeight="{Binding CaptionFontWeight}"
                                 FontStyle="{Binding CaptionFontStyle}"
                                 Foreground="{Binding CaptionForeground}"
                                 TextAlignment="{Binding CaptionAlignment}"
                                 TextBlock.LineHeight="{Binding CaptionLineHeight}"
                                 TextBlock.LineStackingStrategy="BlockLineHeight"
                                 TextWrapping="Wrap"
                                 BorderBrush="#FF7EA6E8"
                                 BorderThickness="1"
                                 Visibility="{Binding IsCaptionEditing, Converter={StaticResource BoolToVisibility}}"
                                 IsVisibleChanged="Editor_IsVisibleChanged"
                                 KeyDown="TableCaptionEditor_KeyDown"
                                 LostFocus="TableCaptionEditor_LostFocus" />
                    </Grid>

                    <DockPanel Margin="1,0,1,2">
                        <TextBlock DockPanel.Dock="Right" Text="{Binding ContinuationText}" FontSize="8.5"
                                   Foreground="#FF8A93A3" FontStyle="Italic" Margin="8,0,0,0" />
                        <TextBlock Text="{Binding Name}" FontSize="9" Foreground="#FF6D7788" TextTrimming="CharacterEllipsis" />
                    </DockPanel>

                    <Border Background="#FFFFF4E5" BorderBrush="#FFF0C06A" BorderThickness="1" Padding="5,3" Margin="1,0,1,3"
                            Visibility="{Binding HasSourceError, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="{Binding SourceError}" FontSize="9.5" Foreground="#FF7A4E00" TextWrapping="Wrap" />
                    </Border>

                    <Border BorderBrush="#FFBFC7D2" BorderThickness="{Binding TableBorderThickness}" ClipToBounds="True">
                        <StackPanel>
                            <ItemsControl ItemsSource="{Binding Columns}"
                                          Visibility="{Binding HasHeader, Converter={StaticResource BoolToVisibility}}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <preview:PreviewTableColumnsPanel Format="{Binding DataContext.Format, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Background="#FFF0F3F7"
                                              MinHeight="{Binding PreferredRowHeight}"
                                              MouseLeftButtonDown="TableHeader_MouseLeftButtonDown">
                                            <Border BorderBrush="#FFCCD2DB" BorderThickness="{Binding CellBorderThickness}" />
                                            <TextBlock Text="{Binding Header}"
                                                       FontFamily="{Binding HeaderFontFamily}"
                                                       FontSize="{Binding HeaderFontSize}"
                                                       FontWeight="{Binding HeaderFontWeight}"
                                                       TextAlignment="{Binding HeaderAlignment}"
                                                       VerticalAlignment="{Binding VerticalAlignment}"
                                                       Margin="{Binding CellMargin}"
                                                       TextWrapping="{Binding TextWrapping}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisibility}}" />
                                            <TextBox Text="{Binding EditText, UpdateSourceTrigger=PropertyChanged}"
                                                     FontFamily="{Binding HeaderFontFamily}"
                                                     FontSize="{Binding HeaderFontSize}"
                                                     FontWeight="{Binding HeaderFontWeight}"
                                                     TextAlignment="{Binding HeaderAlignment}"
                                                     VerticalContentAlignment="Center"
                                                     Margin="1" Padding="{Binding CellMargin}"
                                                     BorderBrush="#FF7EA6E8" BorderThickness="1"
                                                     Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}"
                                                     IsVisibleChanged="Editor_IsVisibleChanged"
                                                     KeyDown="HeaderEditor_KeyDown"
                                                     LostFocus="HeaderEditor_LostFocus" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <preview:PreviewTableGridControl Rows="{Binding Rows}"
                                                             CellSpans="{Binding CellSpans}"
                                                             ColumnCount="{Binding Columns.Count}"
                                                             Format="{Binding Format}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:PreviewTocPageBlockViewModel}">
            <Border Style="{StaticResource PageBlockContainer}" Width="{Binding Width}" Height="{Binding Height}">
                <ItemsControl ItemsSource="{Binding Entries}" Margin="2">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="{Binding Indent, Converter={StaticResource IndentToThickness}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Text}" FontSize="10.5" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="1" Text="{Binding PageNumber}" FontSize="10.5" Margin="12,0,0,0" HorizontalAlignment="Right" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:PreviewImagePageBlockViewModel}">
            <Border Style="{StaticResource PageBlockContainer}" Width="{Binding Width}" Height="{Binding Height}">
                <Grid Margin="2">
                    <Image Source="{Binding ImageSource}" Stretch="Uniform"
                           Visibility="{Binding HasImage, Converter={StaticResource BoolToVisibility}}" />
                    <Border BorderBrush="#FFB9C2CE" BorderThickness="1" Background="#FFF5F6F8"
                            Visibility="{Binding HasImage, Converter={StaticResource InverseBoolToVisibility}}">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="Görsel önizlemesi yok" FontSize="10" Foreground="#FF7D8796" HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding Name}" FontSize="9" Foreground="#FF9AA2AE" HorizontalAlignment="Center" Margin="0,3,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:PreviewPageNumberBlockViewModel}">
            <Border Style="{StaticResource PageBlockContainer}" Width="{Binding Width}" Height="{Binding Height}">
                <TextBlock Text="{Binding PageNumber}" FontSize="9.5" Foreground="#FF6F7783"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:PreviewUnsupportedPageBlockViewModel}">
            <Border Style="{StaticResource PageBlockContainer}" Width="{Binding Width}" Height="{Binding Height}">
                <Border BorderBrush="#FFD2A55F" BorderThickness="1" Background="#FFFFF8EA" Padding="6,4">
                    <StackPanel>
                        <TextBlock Text="DESTEKLENMEYEN İÇERİK" FontSize="8.5" FontWeight="Bold" Foreground="#FF8A641F" />
                        <TextBlock Text="{Binding Description}" FontSize="9.5" Foreground="#FF765B2B" TextWrapping="Wrap" Margin="0,2,0,0" />
                    </StackPanel>
                </Border>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:PreviewPageViewModel}">
            <Border Width="{Binding Width}" Height="{Binding Height}"
                    Background="White" BorderBrush="#FFC8CED8" BorderThickness="1"
                    Margin="0,0,0,28" HorizontalAlignment="Center" ClipToBounds="True">
                <Border.Effect>
                    <DropShadowEffect Color="#FF1E2A3D" Direction="270" ShadowDepth="5" BlurRadius="22" Opacity="0.20" />
                </Border.Effect>
                <ItemsControl ItemsSource="{Binding Blocks}" Width="{Binding Width}" Height="{Binding Height}" ClipToBounds="True">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas ClipToBounds="True" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{Binding X}" />
                            <Setter Property="Canvas.Top" Value="{Binding Y}" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                </ItemsControl>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Background="{DynamicResource Brush.App.Background}"
          AllowDrop="True"
          DragEnter="ReportDesigner_DragEnter"
          DragOver="ReportDesigner_DragOver"
          DragLeave="ReportDesigner_DragLeave"
          Drop="ReportDesigner_Drop">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" MinHeight="46" Background="{DynamicResource Brush.Soft}"
                BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,0,1">
            <Grid Margin="10,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="RAPOR TASARIMI" FontSize="11" FontWeight="Bold" Foreground="#FF596579"
                               VerticalAlignment="Center" Margin="0,0,10,0" />
                    <Button Content="{Binding FrontMatterActionText}" Style="{StaticResource Btn.Mini}"
                            Command="{Binding AddFrontMatterCommand}" VerticalAlignment="Center" />
                    <Button Content="Kaldır" Style="{StaticResource Btn.Mini}" Command="{Binding RemoveFrontMatterCommand}"
                            Margin="6,0,0,0" VerticalAlignment="Center"
                            Visibility="{Binding HasFrontMatter, Converter={StaticResource BoolToVisibility}}" />
                    <Button Content="{Binding ReferenceFormatActionText}" Style="{StaticResource Btn.Mini}"
                            Command="{Binding AddReferenceFormatCommand}" Margin="10,0,0,0" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding ReferenceFormatFileName}" FontSize="9.5" Foreground="#FF7D8796"
                               VerticalAlignment="Center" Margin="6,0,0,0" MaxWidth="150" TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding ReferenceFormatFileName}"
                               Visibility="{Binding HasReferenceFormat, Converter={StaticResource BoolToVisibility}}" />
                    <TextBlock Text="{Binding PageCountText}" FontSize="9.5" Foreground="#FF7D8796"
                               VerticalAlignment="Center" Margin="10,0,0,0" />
                </StackPanel>

                <TextBlock Grid.Column="1" Text="{Binding SurfaceStatusText}" FontSize="9.5"
                           Foreground="#FF7A8493" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"
                           Margin="14,0" ToolTip="{Binding SurfaceStatusText}" />

                <ComboBox Grid.Column="2" Width="138" VerticalAlignment="Center" SelectedValue="{Binding ZoomOption}" SelectedValuePath="Tag">
                    <ComboBoxItem Content="Sayfaya Sığdır" Tag="{x:Static vm:PreviewZoomOption.FitPage}" />
                    <ComboBoxItem Content="Genişliğe Sığdır" Tag="{x:Static vm:PreviewZoomOption.FitWidth}" />
                    <ComboBoxItem Content="%75" Tag="{x:Static vm:PreviewZoomOption.Percent75}" />
                    <ComboBoxItem Content="%100" Tag="{x:Static vm:PreviewZoomOption.Percent100}" />
                    <ComboBoxItem Content="%125" Tag="{x:Static vm:PreviewZoomOption.Percent125}" />
                    <ComboBoxItem Content="%150" Tag="{x:Static vm:PreviewZoomOption.Percent150}" />
                </ComboBox>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <ScrollViewer x:Name="Scroller" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                          SizeChanged="Scroller_SizeChanged" Focusable="True">
                <ItemsControl ItemsSource="{Binding Pages}" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="32,28,32,0"
                              VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
                    <ItemsControl.LayoutTransform>
                        <ScaleTransform ScaleX="{Binding ZoomFactor}" ScaleY="{Binding ZoomFactor}" />
                    </ItemsControl.LayoutTransform>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>

            <Border Margin="28" CornerRadius="8" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1"
                    Background="#FFF7F8FA" Padding="22" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding HasPages, Converter={StaticResource InverseBoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="Önizlenecek sayfa yok" FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding SurfaceStatusText}" FontSize="10.5" Foreground="{DynamicResource Brush.Text.Secondary}"
                               TextWrapping="Wrap" TextAlignment="Center" Margin="0,5,0,10" MaxWidth="440" />
                    <Button Content="Ön Belge Ekle" Style="{StaticResource Btn.Mini}" Command="{Binding AddFrontMatterCommand}" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="1" Margin="18" CornerRadius="14" BorderThickness="2"
                BorderBrush="{DynamicResource Brush.Accent}" Background="#DDEFF5FF"
                IsHitTestVisible="False"
                Visibility="{Binding IsFrontMatterDropActive, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Text="DOCX'i ön belge olarak bırakın" FontSize="17" FontWeight="SemiBold"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
    </Grid>
</UserControl>
